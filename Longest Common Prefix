class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        if(strs.size()==0)
        return "";
        string word=strs[0];
        for(int i=1;i<strs.size();i++)
        {
            while(strs[i].find(word)!=0){
                word=word.substr(0,word.length()-1);
                if(word=="")
                return "";
            }
        }
        return word;
    }
};
